#!/bin/bash

set -e

echo "🔐 Running pre-commit checks..."

# 1. Tests (if test script exists)
# pretest hook automatically runs Biome checks
echo "🧪 Running tests (with pretest checks)..."
if ! npm run test --if-present; then
  echo "❌ Tests failed. Please fix the tests and try again."
  exit 1
fi

# 2. Build verification (if build script exists)
# prebuild hook automatically runs Biome checks and TypeScript type check
echo "🏗️  Running build verification (with prebuild checks)..."
if ! npm run build --if-present; then
  echo "❌ Build failed. Please fix the errors and try again."
  exit 1
fi

echo "✅ All pre-commit checks passed!"
