#!/bin/bash

set -e

echo "🔐 Running pre-commit checks..."

# 1. Biome: format + lint, then re-stage any auto-fixes on already-staged files.
# Whole-tree `npm run check` honors the project's script convention; re-adding only
# the originally-staged files keeps unrelated working-tree edits out of the commit.
echo "🎨 Running Biome (format + lint)..."
staged=$(git diff --cached --name-only --diff-filter=ACMR)
if ! npm run check; then
  echo "❌ Biome reported unfixable problems. Please resolve them and try again."
  exit 1
fi
if [ -n "$staged" ]; then
  echo "$staged" | xargs -r git add
fi

# 2. TypeScript type check (vite build does not type-check on its own)
echo "🔎 Running TypeScript type check..."
if ! npm run typecheck; then
  echo "❌ Type check failed. Please fix the errors and try again."
  exit 1
fi

# 3. Tests (pretest re-runs Biome check; fast and idempotent after step 1)
echo "🧪 Running tests..."
if ! npm run test --if-present; then
  echo "❌ Tests failed. Please fix the tests and try again."
  exit 1
fi

# 4. Build verification
echo "🏗️  Running build verification..."
if ! npm run build --if-present; then
  echo "❌ Build failed. Please fix the errors and try again."
  exit 1
fi

echo "✅ All pre-commit checks passed!"
