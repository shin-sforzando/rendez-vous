#!/bin/bash

set -e

echo "🚀 Running pre-push checks..."

# Regenerate CHANGELOG.md with git-cliff
if command -v git-cliff &> /dev/null; then
  echo "📝 Generating CHANGELOG.md with git-cliff..."
  git cliff --output CHANGELOG.md

  # Auto-commit and abort: the push refs are already resolved before this
  # hook runs, so a new commit made here cannot ride the current push. The
  # user must re-run `git push` to include the CHANGELOG-only commit.
  if ! git diff --quiet -- CHANGELOG.md; then
    echo "  ↳ CHANGELOG.md was updated, creating an auto-commit..."
    # Skip pre-commit checks: tests and build were already validated for the
    # source changes, and a CHANGELOG-only delta cannot affect their outcome.
    git commit --no-verify -o CHANGELOG.md -m "docs: :notebook: update CHANGELOG.md on $(date '+%B %-d, %Y')"
    echo "❌ CHANGELOG.md was committed. Please run 'git push' again to include it."
    exit 1
  fi

  echo "  ✓ CHANGELOG.md is up to date"
else
  echo "  ⚠️  git-cliff not found, skipping CHANGELOG generation"
fi

echo "✅ All pre-push checks passed!"
